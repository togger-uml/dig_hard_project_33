# project_3.sdc
# Synopsys Design Constraints for the temperature-measurement project.
#
# Clock domains
# ─────────────
# main_clock  – 50 MHz board oscillator  (CLOCK_50, period 20 ns)
#               Also the PLL reference input (÷5 → 10 MHz PLL output)
# clk_div     – 1 MHz derived ADC clock  (clk_dft from max10_adc,
#               generated by the ADC's internal 10÷10 divider)
#
# The consumer (CLOCK_50) and producer (clk_div) domains are
# asynchronous; a set_clock_groups constraint prevents the timing
# analyser from attempting cross-domain paths that are intentionally
# handled by the FIFO synchroniser.

# ---------------------------------------------------------------------------
# 50 MHz consumer clock (also PLL reference)
# ---------------------------------------------------------------------------
create_clock -period 20.0  [get_ports CLOCK_50]
create_clock -period 20.0  -name main_clock_virt

# ---------------------------------------------------------------------------
# 10 MHz PLL output clock (intermediate; drives max10_adc pll_clk input).
# Declared as a generated clock derived from CLOCK_50 through the PLL.
#
# Adjust the -source and target pin paths to match the exact net names
# that Quartus assigns after elaboration (visible in the Compilation
# Report → Fitter → Resource Section, or the TimeQuest Netlist Viewer).
# ---------------------------------------------------------------------------
create_generated_clock \
    -name    pll_c0 \
    -source  [get_pins {pll_inst|altpll_component|auto_generated|pll1|inclk[0]}] \
    -divide_by  5 \
    -multiply_by 1 \
    [get_pins {pll_inst|altpll_component|auto_generated|pll1|clk[0]}]

# ---------------------------------------------------------------------------
# 1 MHz derived clock produced by the ADC's internal clock divider.
# Sourced from the PLL c0 output; appears on max10_adc's clk_dft pin.
# ---------------------------------------------------------------------------
create_generated_clock \
    -name    clk_div \
    -source  [get_pins {pll_inst|altpll_component|auto_generated|pll1|clk[0]}] \
    -divide_by  10 \
    -multiply_by 1 \
    [get_pins {adc_inst|primitive_instance|clk_dft}]

# ---------------------------------------------------------------------------
# Declare the consumer and producer domains as asynchronous.
# All paths crossing these domains go through the fifo_sync two-flop
# synchronisers and must NOT be analysed as synchronous paths.
# ---------------------------------------------------------------------------
set_clock_groups \
    -asynchronous \
    -group [get_clocks {CLOCK_50 main_clock_virt}] \
    -group [get_clocks {pll_c0 clk_div}]

# ---------------------------------------------------------------------------
# Input / output delays (adjust to match board routing once known)
# ---------------------------------------------------------------------------
set_input_delay  -clock main_clock_virt -max 1.0 [get_ports {KEY[*]}]
set_input_delay  -clock main_clock_virt -min 0.0 [get_ports {KEY[*]}]

set_output_delay -clock main_clock_virt -max 1.0 [get_ports {HEX*}]
set_output_delay -clock main_clock_virt -min 0.0 [get_ports {HEX*}]

# project_3.sdc
# Synopsys Design Constraints for the temperature-measurement project.
#
# Clock domains
# ─────────────
# main_clock  – 50 MHz board oscillator  (CLOCK_50, period 20 ns)
# adc_clock   – 10 MHz ADC reference     (ADC_CLK_10, period 100 ns)
# clk_div     – 1 MHz derived ADC clock  (clk_dft from max10_adc,
#               generated by the ADC's internal 10÷10 divider)
#
# The two primary domains are asynchronous; a set_clock_groups
# constraint prevents the timing analyser from attempting cross-domain
# paths that are intentionally handled by the FIFO synchroniser.

# ---------------------------------------------------------------------------
# 50 MHz consumer clock
# ---------------------------------------------------------------------------
create_clock -period 20.0  [get_ports CLOCK_50]
create_clock -period 20.0  -name main_clock_virt

# ---------------------------------------------------------------------------
# 10 MHz ADC reference clock
# ---------------------------------------------------------------------------
create_clock -period 100.0 [get_ports ADC_CLK_10]
create_clock -period 100.0 -name adc_clock_virt

# ---------------------------------------------------------------------------
# 1 MHz derived clock produced by the ADC's internal clock divider.
# The source is the PLL output pin; the divided result appears on the
# clk_dft port of the max10_adc instance (adc_inst).
#
# Adjust the -source pin path to match the exact net name that Quartus
# assigns after elaboration (visible in the Compilation Report → Fitter →
# Resource Section, or via the TimeQuest Netlist Viewer).
# ---------------------------------------------------------------------------
create_generated_clock \
    -name    clk_div \
    -source  [get_pins {pll_inst|altpll_component|auto_generated|pll1|clk[0]}] \
    -divide_by  10 \
    -multiply_by 1 \
    [get_pins {adc_inst|primitive_instance|clk_dft}]

# ---------------------------------------------------------------------------
# Declare the two primary clock domains as asynchronous.
# All paths that cross these domains go through the fifo_sync
# two-flop synchronisers and must NOT be analysed as synchronous paths.
# ---------------------------------------------------------------------------
set_clock_groups \
    -asynchronous \
    -group [get_clocks {CLOCK_50   main_clock_virt}] \
    -group [get_clocks {ADC_CLK_10 adc_clock_virt clk_div}]

# ---------------------------------------------------------------------------
# Input / output delays (adjust to match board routing once known)
# ---------------------------------------------------------------------------
set_input_delay  -clock main_clock_virt -max 1.0 [get_ports {KEY[*]}]
set_input_delay  -clock main_clock_virt -min 0.0 [get_ports {KEY[*]}]

set_output_delay -clock main_clock_virt -max 1.0 [get_ports {HEX*}]
set_output_delay -clock main_clock_virt -min 0.0 [get_ports {HEX*}]
